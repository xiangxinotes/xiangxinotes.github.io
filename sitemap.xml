---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">
<url>
	<loc>{{ site.url }}</loc>
	<lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
	<changefreq>weekly</changefreq>
	<priority>1.0</priority>
</url>
{% for post in site.posts %}
<url>
	<loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
	{% if post.last_modified_at %}
	<lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
	{% else %}
	<lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
	{% endif %}
	<changefreq>yearly</changefreq>
	<priority>{{ post.priority | default: 0.8 }}</priority>
</url>
{% endfor %}

{% assign allow_tags = "product,early-retirement,sojourn,workplace,book,driver's-license" %}

{% for page in site.pages %}
{% assign is_allow_tags = false %}
{% if page.url contains 'tag/' %}
	{% assign current_tag = page.url | remove:'/tag/' | remove:'/' %}
	{% if allow_tags contains current_tag and current_tag != '' %}
		{% assign is_allow_tags = true %}
	{% endif %}
{% endif %}

{% if is_allow_tags %}
<url>
	<loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
	{% if page.last_modified_at %}
	<lastmod>{{ page.last_modified_at | date_to_xmlschema }}</lastmod>
	{% else %}
	<lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
	{% endif %}
	<changefreq>weekly</changefreq>
	<priority>{{ page.priority | default: 0.6 }}</priority>
</url>
{% else %}
{% unless page.url contains 'page/' or page.url contains 'tag/' or page.url contains 'assets/' or page.url == '/404.html' or page.url == '/index.html' or page.url == '/' or page.url == '/sitemap.xml' or page.url contains '.json' %}
<url>
	<loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
	{% if post.last_modified_at %}
	<lastmod>{{ post.last_modified_at | date_to_xmlschema }}</lastmod>
	{% else %}
	<lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
	{% endif %}
	<changefreq>yearly</changefreq>
	<priority>{{ page.priority | default: 0.5 }}</priority>
</url>
{% endunless %}
{% endif %}
{% endfor %}
</urlset>